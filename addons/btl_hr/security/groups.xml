<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_btl_hr" model="ir.module.category">
        <field name="name">BTL - Quản lý Nhân sự</field>
        <field name="description">Phân quyền cho hệ thống quản lý nhân sự BTL</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_btl_hr_user" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="category_id" ref="module_category_btl_hr"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_btl_hr_manager" model="res.groups">
        <field name="name">Quản lý Nhân sự</field>
        <field name="category_id" ref="module_category_btl_hr"/>
        <field name="implied_ids" eval="[(4, ref('group_btl_hr_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
