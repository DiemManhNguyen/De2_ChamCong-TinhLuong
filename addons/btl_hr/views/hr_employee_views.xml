<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//h1" position="before">
                <label for="ma_dinh_danh" class="oe_edit_only" string="Mã nhân viên"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="before">
                <field name="ma_dinh_danh" placeholder="NV001" class="oe_inline"/> - 
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <br/>
                <field name="btl_state" widget="badge" decoration-success="btl_state == 'official'" decoration-info="btl_state == 'probation'" decoration-danger="btl_state == 'resigned'"/>
            </xpath>
            <xpath expr="//field[@name='work_email']" position="after">
                <field name="ho_ten_dem"/>
                <field name="ten_nhan_vien"/>
                <field name="que_quan"/>
                <field name="vat_code"/>
            </xpath>
            <xpath expr="//page[@name='personal_information']//group//group[1]" position="inside">
                <field name="bank_account"/>
                <field name="bank_name"/>
            </xpath>
            <xpath expr="//page[@name='personal_information']" position="after">
                <page name="family" string="Gia đình (BTL)">
                    <field name="family_ids">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="relationship"/>
                            <field name="birth_date"/>
                            <field name="is_dependent"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_employee_tree_inherit" model="ir.ui.view">
        <field name="name">hr.employee.tree.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="ma_dinh_danh"/>
            </xpath>
        </field>
    </record>

    <record id="action_btl_hr_employee" model="ir.actions.act_window">
        <field name="name">Danh sách Nhân viên</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Hãy bắt đầu bằng cách thêm một nhân viên mới!
            </p>
        </field>
    </record>
</odoo>
