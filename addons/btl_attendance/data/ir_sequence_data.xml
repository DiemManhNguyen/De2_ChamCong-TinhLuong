<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Đánh mã tự động cho Văn bản / Đơn từ -->
        <record id="seq_btl_leave" model="ir.sequence">
            <field name="name">Mã văn bản Đơn từ</field>
            <field name="code">btl.leave</field>
            <field name="prefix">VB/%(year)s/%(month)s/</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
